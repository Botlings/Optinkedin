# ─── Serveur ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── CSRF ────────────────────────────────────────────────────────────────────
# Secret HMAC-SHA256 pour signer les tokens CSRF. Minimum 32 caractères.
# Génération : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=REMPLACER_PAR_UNE_VALEUR_ALEATOIRE_DE_64_CHARS_MIN

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://botlings.github.io

# ─── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_ANALYZE=10
RATE_LIMIT_RECO=5

# ─── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-REMPLACER

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Clé secrète Stripe (Dashboard > Developers > API keys > Secret key)
# Format : sk_live_... (production) ou sk_test_... (test)
STRIPE_SECRET_KEY=sk_live_REMPLACER

# Secret de validation des webhooks Stripe (Dashboard > Webhooks > Signing secret)
# Format : whsec_...
# À configurer sur l'endpoint : https://[votre-app].railway.app/api/stripe/webhook
# Événement à écouter : checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_REMPLACER

# Durée de vie des sessions de paiement en mémoire (millisecondes). Défaut : 3600000 (1h)
SESSION_TTL_MS=3600000

# ─── Logs ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info