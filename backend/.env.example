# ─── Serveur ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── CSRF ────────────────────────────────────────────────────────────────────
# Secret HMAC-SHA256 pour signer les tokens CSRF. Minimum 32 caractères.
# Génération : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=REMPLACER_PAR_UNE_VALEUR_ALEATOIRE_DE_64_CHARS_MIN

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://botlings.github.io

# ─── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_ANALYZE=10
RATE_LIMIT_RECO=5

# ─── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-REMPLACER

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=whsec_REMPLACER

# ─── Logs ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info