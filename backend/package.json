{
  "name": "optinkedin-backend",
  "version": "1.0.0",
  "description": "API backend OptinkedIn — Node.js / Express / TypeScript",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsup src/server.ts --format esm --out-dir dist --dts",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "stripe": "^16.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}